# Azure AI Foundry (chat model used by the reconciliation agent)
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL=gpt-4o

# Azure SQL ledger database (read-only). 
SQL_SERVER=<SERVER>.database.windows.net
SQL_DATABASE=<DB>

# Seconds to wait for the serverless DB to resume before a login times out.
SQL_LOGIN_TIMEOUT=90
